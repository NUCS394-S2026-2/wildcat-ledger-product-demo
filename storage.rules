rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read and write anything
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow unauthenticated uploads to receipt paths so recipients can submit
    // receipts via the /upload-receipt page without logging in
    match /clubs/{orgId}/transactions/{transactionId}/{filename} {
      allow write: if filename.matches('receipt_.*');
      allow read: if request.auth != null;
    }
  }
}
