rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /clubs/{clubId} {

      function email() {
        return request.auth.token.email;
      }

      // For the club document itself (read/update rules), resource.data is the club doc
      function canManageClub(d) {
        return (('admins' in d) && email() in d.admins) ||
               (('treasurers' in d) && email() in d.treasurers) ||
               (('presidents' in d) && email() in d.presidents);
      }

      function isMemberOfClub(d) {
        return canManageClub(d) || (('officers' in d) && email() in d.officers);
      }

      // For subcollections, look up the parent club
      function clubDoc() {
        return get(/databases/$(database)/documents/clubs/$(clubId)).data;
      }

      function canManage() { return canManageClub(clubDoc()); }
      function isMember() { return isMemberOfClub(clubDoc()); }

      allow read: if request.auth != null && isMemberOfClub(resource.data);
      allow create: if request.auth != null;
      allow update: if request.auth != null && canManageClub(resource.data);
      allow delete: if false;

      match /transactions/{txnId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && isMember();
        allow update: if request.auth != null && (
          canManage() ||
          (isMember() &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['exemptionFormUrl']))
        );
        allow delete: if request.auth != null && canManage();
      }

      match /auditLog/{entryId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && isMember();
        allow update, delete: if false;
      }

      match /pendingChanges/{changeId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && canManage();
        allow delete: if request.auth != null && canManage();
        allow update: if false;
      }

      match /reloadRequests/{requestId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && canManage();
        allow update, delete: if false;
      }
    }
  }
}
